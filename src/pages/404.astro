---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" description="The page you requested could not be found.">
  <main class="section page-top">
    <div class="container content-page">
      <p class="eyebrow">404</p>
      <h1>Page not found.</h1>
      <p>The page you requested does not exist or may have been moved.</p>
      <a class="button primary" href="/">Go Home</a>
    </div>
  </main>
</BaseLayout>
