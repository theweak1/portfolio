---
import BaseLayout from "../layouts/BaseLayout.astro";
import profile from "../data/profile.js";
import projects from "../data/projects.js";
---

<BaseLayout
	title={`Projects | ${profile.name}`}
	description="A collection of software, automation, and technical documentation projects."
>
	<main class="section page-top">
		<div class="container section-heading">
			<p class="eyebrow">Projects</p>
			<h1>Selected work</h1>
			<p>
				Each project is written as a practical case study: the problem, the
				solution, the tools, and the result.
			</p>
		</div>

		<div class="container project-list">
			{
				projects.map((project) => (
					<article class="project-detail" id={project.slug}>
						<div>
							<div
								class="tech-stack"
								aria-label={`${project.title} tech stack`}
							>
								{project.tech.map((item) => (
									<span class="tech-badge">{item}</span>
								))}
							</div>
							<h2>{project.title}</h2>
							<p>{project.description}</p>

							<div class="project-actions">
								<a class="button primary" href={`/projects/${project.slug}`}>
									Read Case Study
								</a>
								{project.githubUrl && (
									<a
										class="button secondary"
										href={project.githubUrl}
										target="_blank"
										rel="noreferrer"
									>
										View GitHub
									</a>
								)}
								{project.liveUrl && (
									<a
										class="button secondary"
										href={project.liveUrl}
										target="_blank"
										rel="noreferrer"
									>
										View Live
									</a>
								)}
							</div>
						</div>

						<div class="detail-card">
							<h3>Highlights</h3>
							<ul class="check-list">
								{project.highlights.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</div>
					</article>
				))
			}
		</div>
	</main>
</BaseLayout>
