---
import BaseLayout from "../layouts/BaseLayout.astro";
import profile from "../data/profile.js";
---

<BaseLayout
  title={`Contact | ${profile.name}`}
  description={`Contact ${profile.name} for software engineering and automation opportunities.`}
>
  <main class="section page-top">
    <div class="container contact-grid">
      <div>
        <p class="eyebrow">Contact</p>
        <h1>Let’s connect.</h1>
        <p>
          I am open to software engineering, automation, and technical workflow projects where practical problem-solving matters.
        </p>
      </div>

      <section class="contact-card" aria-label="Contact links">
        <h2>Links</h2>
        <a href={`mailto:${profile.email}`}>{profile.email}</a>
        {profile.github && <a href={profile.github} target="_blank" rel="noreferrer">GitHub</a>}
        {profile.linkedin ? (
          <a href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
        ) : (
          <p class="small-note">Add your LinkedIn URL in <code>src/data/profile.js</code>.</p>
        )}
      </section>
    </div>
  </main>
</BaseLayout>
