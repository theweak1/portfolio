<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="section page-top">
  <div class="container section-heading">
    <p class="eyebrow">Projects</p>
    <h1>Selected work</h1>
    <p>Each project is written as a practical case study: the problem, the solution, the tools, and the result.</p>
  </div>

  <div class="container project-list">
    <% projects.forEach(project => { %>
      <article class="project-detail" id="<%= project.slug %>">
        <div>
          <p class="project-type"><%= project.tech.join(' · ') %></p>
          <h2><%= project.title %></h2>
          <p><%= project.description %></p>

          <div class="project-actions">
            <% if (project.githubUrl) { %>
              <a class="button primary" href="<%= project.githubUrl %>" target="_blank" rel="noreferrer">View GitHub</a>
            <% } %>
            <% if (project.liveUrl) { %>
              <a class="button secondary" href="<%= project.liveUrl %>" target="_blank" rel="noreferrer">View Live</a>
            <% } %>
          </div>
        </div>

        <div class="detail-card">
          <h3>Highlights</h3>
          <ul class="check-list">
            <% project.highlights.forEach(item => { %>
              <li><%= item %></li>
            <% }) %>
          </ul>
        </div>
      </article>
    <% }) %>
  </div>
</main>

<%- include('partials/footer') %>
