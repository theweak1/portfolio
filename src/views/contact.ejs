<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="section page-top">
  <div class="container contact-grid">
    <div>
      <p class="eyebrow">Contact</p>
      <h1>Let’s connect.</h1>
      <p>
        I am open to software engineering, automation, and technical workflow projects where practical problem-solving matters.
      </p>
    </div>

    <section class="contact-card" aria-label="Contact links">
      <h2>Links</h2>
      <a href="mailto:<%= profile.email %>"><%= profile.email %></a>
      <% if (profile.github) { %>
        <a href="<%= profile.github %>" target="_blank" rel="noreferrer">GitHub</a>
      <% } %>
      <% if (profile.linkedin) { %>
        <a href="<%= profile.linkedin %>" target="_blank" rel="noreferrer">LinkedIn</a>
      <% } else { %>
        <p class="small-note">Add your LinkedIn URL in <code>src/data/profile.js</code>.</p>
      <% } %>
    </section>
  </div>
</main>

<%- include('partials/footer') %>
