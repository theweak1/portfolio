<%- include('partials/head') %>
<%- include('partials/nav') %>

<main>
  <section class="hero section">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Software Engineering · Automation · Technical Systems</p>
        <h1><%= profile.role %></h1>
        <p class="hero-copy"><%= profile.headline %></p>
        <div class="hero-actions">
          <a class="button primary" href="/projects">View Projects</a>
          <a class="button secondary" href="/contact">Contact Me</a>
        </div>
      </div>

      <aside class="hero-card" aria-label="Portfolio summary">
        <h2>Focus Areas</h2>
        <ul class="check-list">
          <li>Automation tools</li>
          <li>Configuration-driven workflows</li>
          <li>Manufacturing system support</li>
          <li>Technical documentation</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section muted">
    <div class="container section-heading">
      <p class="eyebrow">Featured Work</p>
      <h2>Projects that show practical engineering</h2>
      <p>These projects highlight software development, automation, troubleshooting, and clear technical communication.</p>
    </div>

    <div class="container project-grid">
      <% featuredProjects.forEach(project => { %>
        <article class="project-card">
          <p class="project-type"><%= project.tech.slice(0, 3).join(' · ') %></p>
          <h3><%= project.title %></h3>
          <p><%= project.summary %></p>
          <a class="text-link" href="/projects#<%= project.slug %>">Read case study</a>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="section">
    <div class="container skills-panel">
      <div>
        <p class="eyebrow">Skills</p>
        <h2>Tools and strengths</h2>
      </div>
      <div class="skill-list">
        <% profile.skills.forEach(skill => { %>
          <span><%= skill %></span>
        <% }) %>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
