---
const { profile, currentPath = "/" } = Astro.props;
const isActive = (href) =>
  href === "/" ? currentPath === "/" : currentPath === href || currentPath.startsWith(`${href}/`);
---

<header class="site-header">
  <nav class="nav container" aria-label="Primary navigation">
    <a class="brand" href="/" aria-label="Home">{profile.name}</a>
    <button
      class="nav-toggle"
      type="button"
      aria-label="Toggle navigation"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="nav-links" data-nav-links>
      <a class:list={[{ active: isActive("/") }]} href="/">Home</a>
      <a class:list={[{ active: isActive("/projects") }]} href="/projects">Projects</a>
      <a class:list={[{ active: isActive("/about") }]} href="/about">About</a>
      <a class:list={[{ active: isActive("/contact") }]} href="/contact">Contact</a>
    </div>
  </nav>
</header>
